# Database Configuration
DB_PATH=storage/leads.db

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Email Sending Limits & Delays
DAILY_EMAIL_LIMIT=100
DELAY_BETWEEN_EMAILS_MIN=5
DELAY_BETWEEN_EMAILS_MAX=10
MAX_RETRIES=3

# LinkedIn Automation
# This is the target page that the bot will open after login
LINKEDIN_DEFAULT_SEARCH_URL=https://www.linkedin.com/search/results/content/?keywords=%22hiring%22%20%22software%22%20%22engineer%22%20%22send%22%20%22resume%22
